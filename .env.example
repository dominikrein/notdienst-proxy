# Kopiere diese Datei nach .env und trage deine echte XML-Schnittstellen-URL ein.
# Die .env ist per .gitignore vom Repo ausgeschlossen (enthaelt den Zugangs-Token).

NOTDIENST_XML_URL=https://notdienst.sberg.net/api/apipub/notdienst/xmlschnittstelle/DEIN_TOKEN_HIER

# Optional (Defaults siehe README):
# NOTDIENST_PORT=8080
# NOTDIENST_BIND=127.0.0.1   # nur auf 0.0.0.0 setzen, wenn Anzeige von anderem Rechner im LAN kommt
# NOTDIENST_FETCH_INTERVAL=600
# NOTDIENST_FETCH_RETRY=30    # Schnell-Retry, solange noch keine Daten da sind (Boot/Netzausfall)
# NOTDIENST_PAGE_REFRESH=300
# NOTDIENST_MAX_ENTRIES=5   # bei Fenster-Scrollbalken auf dem 640x480-Panel: 4
# NOTDIENST_PIXELSHIFT=0     # Anti-Burn-in-Pixelshift abschalten (Default an: Inhalt wandert wenige px pro Refresh)
# NOTDIENST_BGCYCLE=0        # Dezente Hintergrund-Tonrotation abschalten (Default an; ergaenzt den Pixelshift)
# NOTDIENST_TZ=Europe/Berlin
# NOTDIENST_LOG=0            # Logging komplett aus (verhindert Wachsen von /var/log/notdienst-proxy.log)
